{
  "env": {
    "browser": true,
    "es2021": true,
    "node": true
  },
  "extends": "eslint:recommended",
  "plugins": ["html"],
  "parserOptions": {
    "ecmaVersion": 13,
    "sourceType": "script"
  },
  "rules": {
    "no-undef": "off",
    "no-unused-vars": "off",
    "no-redeclare": "error",
    "no-duplicate-case": "error",
    "no-unreachable": "error"
  }
}
